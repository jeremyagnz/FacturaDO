# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=facturado
DB_PASSWORD=facturado_dev
DB_DATABASE=facturado
DB_SSL=false
DB_LOGGING=true
DB_MAX_CONNECTIONS=20

# JWT Authentication
JWT_ACCESS_SECRET=change-me-super-secret-access-key-at-least-32-chars
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=facturado
JWT_AUDIENCE=facturado-api

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=facturado:
REDIS_TTL=3600

# Cloudflare R2 Storage
STORAGE_PROVIDER=r2
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=facturado
R2_PUBLIC_URL=https://your-custom-domain.com

# DGII Integration
DGII_ENV=sandbox
DGII_SANDBOX_URL=https://ecf.dgii.gov.do/testecf
DGII_PRODUCTION_URL=https://ecf.dgii.gov.do
DGII_TIMEOUT=30000
DGII_RETRIES=3
DGII_CERT_PATH=
DGII_CERT_PASSWORD=
